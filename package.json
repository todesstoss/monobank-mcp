{
  "name": "@todesstoss/monobank-mcp",
  "version": "0.0.1",
  "description": "MCP server for Monobank — accounts, transactions, exchange rates, and webhooks for Claude and other MCP clients",
  "type": "module",
  "main": "dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "bin": {
    "monobank-mcp": "dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "start": "node src/index.ts",
    "inspect": "dotenv mcp-inspector node src/index.ts",
    "prepare": "husky || true",
    "lint": "eslint src"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "monobank",
    "mono",
    "monobank mcp",
    "monobank mcp server",
    "mcp",
    "mcp server",
    "model context protocol"
  ],
  "engines": {
    "node": ">=24.17.0"
  },
  "author": "Yevgenii Mikhnytskyi",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "currency-codes": "^2.2.0",
    "dotenv": "^17.4.2",
    "node-cache": "^5.1.2",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^25.9.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
